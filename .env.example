# Frontend (Netlify) — copy to .env.production or set as Netlify env var
VITE_API_BASE_URL=https://your-render-backend.onrender.com

# Backend (Render) — add these to server/.env or as Render env vars
MONGODB_URI=mongodb+srv://...
JWT_SECRET=your-secret
JWT_EXPIRES_IN=7d
CLOUDINARY_URL=cloudinary://...
FRONTEND_URL=https://your-netlify-site.netlify.app

# AI Study Assistant — free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
